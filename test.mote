// Functions
fn add(a, b):
    return a + b

print(
    add(
        3, 
        4
    )
)

// Conditionals
if x > 5:
    print("x is large")
else:
    print("x is small")

// Loops
let i = 0
while i < 5:
    print(i)
    i = i + 1
